{
  "schemaVersion": 1,
  "decision": "reviewed-exact-fingerprint-baseline-with-zero-growth",
  "scope": ["theme/**/*.js", "theme/**/*.mjs"],
  "rationale": "Solstice intentionally renders Press-sanitized content, reviewed Press renderer output, and owned escaped or static templates. Exact normalized semantic AST fingerprints pin each sink to its full lexical owner and full-file AST path so equivalent source cannot move between contexts without review.",
  "wrappers": [
    {
      "name": "renderLoader",
      "rationale": "renderLoader owns a live-DOM status template; every call is fingerprinted so message-source or caller growth requires review."
    },
    {
      "name": "renderStaticView",
      "rationale": "renderStaticView combines escaped theme chrome with Press-rendered static content; every call remains an explicit reviewed boundary."
    },
    {
      "name": "showToc",
      "rationale": "showToc accepts Press-rendered table-of-contents markup and owns the fallback live-DOM insertion path, so all callers are fingerprinted."
    }
  ],
  "expectedKinds": {
    "html-wrapper-call:renderLoader": 2,
    "html-wrapper-call:renderStaticView": 1,
    "html-wrapper-call:showToc": 2,
    "innerHTML-write": 23
